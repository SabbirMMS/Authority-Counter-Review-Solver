# GitHub access
GITHUB_TOKEN=ghp_xxx_modify_here
GITHUB_API_URL=https://api.github.com
GITHUB_ORG=ftpsofts

# Comma-separated allowlists for employee identity checks
EMPLOYEE_GITHUB_LOGINS=alice,bob,sabbirFTP,ftpsofts
EMPLOYEE_EMAILS=alice@company.com,bob@company.com,sabbir@fintech-point.com

# Local rules file (maintained manually)
RULES_PATH=rules/rules.json

# Comma-separated paths to skip (directory prefixes or exact files, for ore framework, vendor code, etc.)
EXCLUDED_DIRS=node_modules/,plugins/owner/,plugins/themes-manager/,vendor/,android/,ios/

# Optional: send visual HTML report to one primary recipient
REPORT_EMAIL=eng-leads@company.com

# Optional: additional recipients in CC
CC_EMAILS=qa@company.com,cto@company.com

# SMTP settings for email delivery (required only when REPORT_EMAIL is set)
SMTP_HOST=smtp.company.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=code-validator@company.com
SMTP_USE_TLS=true

# Defaults used by CLI flags when omitted
DEFAULT_REPO=
DEFAULT_BRANCH=main
